<Window x:Class="Financial.Presentation.App.OperationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Height="360"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" FontWeight="Bold" Margin="0,0,0,8">
            <TextBlock.Text>
                <MultiBinding StringFormat="{}{0} / {1} / {2}">
                    <Binding Path="BrokerName"/>
                    <Binding Path="PortfolioName"/>
                    <Binding Path="AssetName"/>
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Date:" VerticalAlignment="Center"/>
        <DatePicker Grid.Row="1" Grid.Column="1"
                    SelectedDate="{Binding Date, UpdateSourceTrigger=PropertyChanged}"
                    IsEnabled="{Binding IsEditable}"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Type:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="2" Grid.Column="1"
                  SelectedValue="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                  SelectedValuePath="Content"
                  IsEnabled="{Binding IsEditable}">
            <ComboBoxItem Content="Buy"/>
            <ComboBoxItem Content="Sell"/>
        </ComboBox>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Quantity:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="3" Grid.Column="1"
                 Text="{Binding Quantity, UpdateSourceTrigger=LostFocus}"
                 IsReadOnly="{Binding IsReadOnly}"
                 PreviewTextInput="OnDecimalTextBoxPreviewTextInput"
                 DataObject.Pasting="OnDecimalTextBoxPasting"
                 LostFocus="OnDecimalTextBoxLostFocus"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Unit Price:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="4" Grid.Column="1"
                 Text="{Binding UnitPrice, UpdateSourceTrigger=LostFocus}"
                 IsReadOnly="{Binding IsReadOnly}"
                 PreviewTextInput="OnDecimalTextBoxPreviewTextInput"
                 DataObject.Pasting="OnDecimalTextBoxPasting"
                 LostFocus="OnDecimalTextBoxLostFocus"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Fees:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="5" Grid.Column="1"
                 Text="{Binding Fees, UpdateSourceTrigger=LostFocus}"
                 IsReadOnly="{Binding IsReadOnly}"
                 PreviewTextInput="OnDecimalTextBoxPreviewTextInput"
                 DataObject.Pasting="OnDecimalTextBoxPasting"
                 LostFocus="OnDecimalTextBoxLostFocus"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Total:" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="6" Grid.Column="1"
                   Text="{Binding TotalPrice, StringFormat=N2}"/>

        <TextBlock Grid.Row="7" Grid.ColumnSpan="2"
                   Foreground="Red"
                   TextWrapping="Wrap"
                   Text="{Binding ValidationMessage}"
                   Margin="0,8,0,0"/>

        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{Binding ConfirmLabel}" Width="90" Command="{Binding ConfirmCommand}"/>
            <Button Content="Cancel" Width="90" Margin="8,0,0,0" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>

