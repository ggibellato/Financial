<Window x:Class="Financial.Presentation.App.MainWindow"
        x:Name="root"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Financial.Presentation.App.Components"
        mc:Ignorable="d"
        Title="Financial tools" Height="800" Width="1200" Icon="{StaticResource AppIcon}">
    <Grid>
        <TabControl SelectedIndex="0" Grid.ColumnSpan="2">
            <TabItem Header="Portfolio Navigator">
                <local:NavigationView DataContext="{Binding ElementName=root, Path=NavigationViewModel}"/>
            </TabItem>
            <TabItem x:Name="dividendCheckTab" Header="Shares Dividend check"/>
            <TabItem x:Name="assetPriceTab" Header="Read Assets current values"/>
        </TabControl>
    </Grid>
</Window>
